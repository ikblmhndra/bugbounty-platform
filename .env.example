# Application
APP_ENV=development
APP_SECRET_KEY=changeme-generate-a-secure-random-key
APP_HOST=0.0.0.0
APP_PORT=8000

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=bugbounty
POSTGRES_USER=bugbounty
POSTGRES_PASSWORD=changeme

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
TELEGRAM_ALLOWED_USERS=123456789,987654321

# Frontend
# Leave empty when using nginx reverse proxy (same-origin /api calls).
# Set to http://localhost:8000 only for direct API access in local dev.
NEXT_PUBLIC_API_URL=

# Tool paths (defaults assume tools are in PATH)
SUBFINDER_PATH=subfinder
ASSETFINDER_PATH=assetfinder
HTTPX_PATH=httpx
GAU_PATH=gau
WAYBACKURLS_PATH=waybackurls
KATANA_PATH=katana
FFUF_PATH=ffuf
NUCLEI_PATH=nuclei
GOWITNESS_PATH=gowitness

# Scan defaults
DEFAULT_SCAN_TIMEOUT=3600
MAX_PARALLEL_TASKS=5
NUCLEI_SEVERITY=low,medium,high,critical
FFUF_WORDLIST=/opt/wordlists/ffuf/common.txt

# Reports output directory
REPORTS_DIR=./reports
SCREENSHOTS_DIR=./screenshots
